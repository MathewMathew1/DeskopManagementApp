<Window x:Class="ModernWpfApp.UpdateDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:comp="clr-namespace:ModernWpfApp.Components.Order.OrderRow"
        Title="Aktualizacja danych"
        Height="600"
        Width="1000"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>
        <!-- Modern DataGrid Header Style -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <Button x:Name="BackToMenu"
                    Content="Powrót do menu"
                    Style="{StaticResource ModernButton}"
                    Width="300"
                    Height="40"
                    Margin="0,5,0,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Click="BackToMenu_Click"/>
            </StackPanel>
        </Grid>
        <WrapPanel Grid.Row="1">
            <Button x:Name="Drewno"
                Content="Gatunki drewna"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateDrewno_Click"/>
       <!--     <Button x:Name="Klienci"
                Content="Klienci"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateKlienci_Click"/>
            <Button x:Name="KlienciAdresy"
                Content="Klienci - adresy"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateKlienciAdresy_Click"/> -->
            <Button x:Name="Kolory"
                Content="Kolory"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateKolory_Click"/>
            <Button x:Name="Krzesla"
                Content="Krzesła"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateChairs_Click"/>
            <Button x:Name="Stoly"
                Content="Stoły"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateTables_Click"/>
            <Button x:Name="DetaleSlizgacze"
                Content="Ślizgacze"
                Style="{StaticResource ModernButton}"
                Width="235"
                Height="60"
                Margin="5,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Click="OnUpdateSlizgacze_Click"/>
        </WrapPanel>
    </Grid>
</Window>
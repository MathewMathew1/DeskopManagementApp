<UserControl x:Class="ModernWpfApp.Components.Order.OrderRow.OrderRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
    
    <Border Background="White"
            Padding="15,10"
            Margin="0,0,0,10"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="8">
        <!-- Optional Shadow -->
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Order ID -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Order ID" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding Id}" FontWeight="Bold" FontSize="14" Foreground="#1E293B"/>
            </StackPanel>

            <!-- User Name -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Customer" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding User.Name}" FontWeight="SemiBold" Foreground="#334155"/>
            </StackPanel>

            <!-- Ordered Items (Modern Tags) -->
           <ItemsControl ItemsSource="{Binding FurnitureInOrders}" MaxHeight="50">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F1F5F9"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    Margin="0,0,4,4">
                                <TextBlock Text="{Binding Furniture.Name}"
                                           FontSize="12"
                                           Foreground="#475569"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <!-- Created At -->
            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                <TextBlock Text="Date" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding CreatedAt}" Foreground="#64748B"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Cancel: Red Button -->
                <Button Content="Cancel"
                        Style="{StaticResource ModernButton}"
                        Background="#EF4444"
                        Width="80" Height="32" Margin="0,0,10,0"/>
                
                <!-- Complete: Green Button -->
                <Button Content="Complete"
                        Style="{StaticResource ModernButton}"
                        Background="#10B981"
                        Width="85" Height="32"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
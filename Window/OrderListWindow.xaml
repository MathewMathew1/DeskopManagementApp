<Window x:Class="ModernWpfApp.OrderListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:comp="clr-namespace:ModernWpfApp.Components.Order.OrderRow"
        Title="Lista zamówień"
        SizeToContent="WidthAndHeight"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>
    </Window.Resources>

    <Grid Width="1800" Height="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <Button x:Name="BackToMenu"
                    Content="Powrót do menu"
                    Style="{StaticResource ModernButton}"
                    Width="300"
                    Height="40"
                    Margin="0,5,0,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Click="BackToMenu_Click"/>
            </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Vertical">
                    <TextBlock Margin="5,0"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Stretch">
                        <Run Text="Zamówienia:" FontSize="10"/>    
                        <Run Text="{Binding TotalOrderCount}"
                                            FontWeight="Bold"
                                            FontSize="12"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                        <TextBlock Text="Klient:" Foreground="#555" Margin="5,0,5,0" Width="100"/>
                        <ComboBox x:Name="TxtComboEklient" ItemsSource="{Binding cbKlienciByOrders}"
                                SelectedItem="{Binding SelectedEKlient, Mode=TwoWay}"
                                Width="250">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontWeight="Bold">
                                            <Run Text="{Binding Firma}"/><Run Text=" ("/><Run Text="{Binding iCount}"/><Run Text=")"/>  
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
        </Grid>
    </Grid>
</Window>
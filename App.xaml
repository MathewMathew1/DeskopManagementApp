<Application x:Class="ModernWpfApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:utils="clr-namespace:ModernWpfApp.Utils"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
         <utils:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- Modern Reusable Button Style -->
        <Style x:Key="ModernButton"
                TargetType="Button">
            <Setter Property="Background"
                    Value="#0078D7"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Padding"
                    Value="15,8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover State -->
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#1084E3"/>
                            </Trigger>
                            <!-- Pressed State -->
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#005A9E"/>
                            </Trigger>
                            <!-- Disabled State (Loading) -->
                            <Trigger Property="IsEnabled"
                                    Value="False">
                                <Setter Property="Background"
                                        Value="#CCCCCC"/>
                                <Setter Property="Foreground"
                                        Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
        <Style x:Key="ModernButtonHover"
                TargetType="Button"
                BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background"
                    Value="#005A9E"/>
        </Style>
        <DropShadowEffect x:Key="DropShadowEffect"
                ShadowDepth="3"
                BlurRadius="8"
                Color="#333"/>
    </Application.Resources>
</Application>